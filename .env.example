# ============================================================
# Web2App AI — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# These are exposed to the browser — use only public keys
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Your deployed Netlify URL (no trailing slash)
VITE_NETLIFY_URL=https://your-app.netlify.app

# ── Netlify Functions (server-side only) ─────────────────────
# These are NEVER exposed to the browser

# Supabase — use the service role key (NOT anon key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub — Personal Access Token with repo + workflow permissions
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=web2app-ai

# Internal secret — used to authenticate GitHub→Netlify callbacks
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=your_random_secret_here_min_32_chars

# Netlify URL (used by functions for callback URLs)
URL=https://your-app.netlify.app
